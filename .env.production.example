NODE_ENV=production
EFFECT_LOG=info
RADIANT_SECURE_COOKIES=true

DATABASE_URL=postgresql://radiant:<POSTGRES_PASSWORD>@postgres.radiant/radiant
REDIS_URL=redis://redis.radiant:6379
RADIANT_STORAGE_ROOT=/app/data/storage

DISCORD_CLIENT_ID=YOUR_DISCORD_CLIENT_ID
DISCORD_CLIENT_SECRET=YOUR_DISCORD_CLIENT_SECRET
DISCORD_REDIRECT_URI=https://stream-radiant.online/auth/callback/discord

GITHUB_CLIENT_ID=YOUR_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=YOUR_GITHUB_CLIENT_SECRET
GITHUB_REDIRECT_URI=https://stream-radiant.online/auth/callback/github

# Optional observability
# RADIANT_OTEL_BASE_URL=https://your-otel-endpoint
# RADIANT_OTEL_HEADERS={\"Authorization\":\"Bearer ...\"}
# RADIANT_OTEL_SERVICE_NAME=radiant-backend
# RADIANT_OTEL_SERVICE_VERSION=1.0.0
# RADIANT_OTEL_EXPORT_INTERVAL_MS=5000

# Optional frontend flags
# NEXT_PUBLIC_ENABLE_DESIGN_SYSTEM=false
