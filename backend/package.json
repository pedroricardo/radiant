{
	"name": "@radiant/backend",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"main": "./index.ts",
	"types": "./index.ts",
	"exports": {
		".": {
			"types": "./index.ts",
			"default": "./index.ts"
		},
		"./lib": {
			"types": "./lib/index.ts",
			"default": "./lib/index.ts"
		},
		"./lib/*": {
			"types": "./lib/*",
			"default": "./lib/*"
		},
		"./services": {
			"types": "./services/index.ts",
			"default": "./services/index.ts"
		},
		"./services/*": {
			"types": "./services/*",
			"default": "./services/*"
		},
		"./environments/*": {
			"types": "./environments/*",
			"default": "./environments/*"
		}
	},
	"dependencies": {
		"@breezystack/lamejs": "^1.2.7",
		"@effect/platform": "^0.94.5",
		"@radiant/client": "workspace:*",
		"arctic": "^3.7.0",
		"drizzle-orm": "^0.45.1",
		"effect": "^3.19.19",
		"postgres": "^3.4.4"
	},
	"devDependencies": {
		"@testcontainers/postgresql": "^10.10.3",
		"@types/bun": "^1.3.10",
		"bun-types": "^1.3.10",
		"drizzle-kit": "^0.31.9",
		"testcontainers": "^11.14.0",
		"typescript": "^5"
	}
}
