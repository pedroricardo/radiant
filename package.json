{
	"name": "radiant",
	"type": "module",
	"private": true,
	"workspaces": [
		"RadiantClient",
		"backend",
		"radiant-frontend",
		"radiant-cli"
	],
	"scripts": {
		"add-test-migration": "bun --env-file=radiant-frontend/.env --bun drizzle-kit generate --config backend/drizzle.config.ts",
		"db:push": "bun --env-file=radiant-frontend/.env --bun drizzle-kit push --config backend/drizzle.config.ts",
		"build": "cd radiant-frontend && npm run build",
		"cli": "bun --cwd=radiant-cli run radiant",
		"dev": "bun run --cwd radiant-frontend dev",
		"start": "bun run --cwd radiant-frontend start",
		"typecheck": "bun run typecheck:backend && bun run typecheck:frontend && bun run typecheck:cli",
		"typecheck:backend": "bunx tsc --noEmit -p backend/tsconfig.json",
		"typecheck:cli": "bun run --cwd radiant-cli typecheck",
		"typecheck:frontend": "bun run --cwd radiant-frontend typecheck",
		"discloud:start": "bun start || cat"
	},
	"devDependencies": {
		"drizzle-kit": "^0.31.9",
		"prettier": "^3.8.1",
		"prettier-plugin-organize-imports": "^4.3.0",
		"typescript": "^5"
	},
	"dependencies": {
		"@effect/opentelemetry": "^0.63.0",
		"@effect/platform-bun": "^0.89.0",
		"@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
		"@opentelemetry/sdk-trace-base": "^2.7.1"
	},
	"patchedDependencies": {
		"next@16.2.6": "patches/next@16.2.6.patch"
	}
}
