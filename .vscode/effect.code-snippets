		"body": [
			"const daemon = Effect.gen(function* () {",
			"  while (true) {",
			"    const msg = yield* Queue.take(queue)",
			"",
			"    switch (msg._tag) {",
			"      case \"$1\": {",
			"        $0",
			"        break",
			"      }",
			"    }",
			"  }",
			"})",
		],
	},

	"Effect Tag": {
		"prefix": "tag",
