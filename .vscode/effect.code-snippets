{
	"Effect.gen": {
		"prefix": "eff",
		"body": ["Effect.gen(function* () {", "  $0", "})"],
	},

	"Effect pipe": {
		"prefix": "effpipe",
		"body": ["pipe(", "  $1,", "  Effect.flatMap(($2) => $0)", ")"],
	},

	"forkScoped": {
		"prefix": "forks",
		"body": ["yield* Effect.forkScoped(", "  $0", ")"],
	},

	"Deferred request pattern": {
		"prefix": "deffn",
		"body": [
			"Effect.gen(function* () {",
			"  const reply = yield* Deferred.make<$1>()",
			"",
			"  yield* Queue.offer($2, {",
			"    $3,",
			"    reply",
			"  })",
			"",
			"  return yield* Deferred.await(reply)",
			"})",
		],
	},

