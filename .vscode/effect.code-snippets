	"Service actor": {
		"prefix": "svcactor",
		"body": [
			"const queue = yield* Queue.unbounded<$1>()",
			"",
			"yield* Effect.forkScoped(",
			"  Effect.gen(function* () {",
			"    while (true) {",
			"      const msg = yield* Queue.take(queue)",
			"      $0",
			"    }",
			"  })",
			")",
		],
	},

	"Batch processor": {
		"prefix": "batch",
		"body": [
			"yield* Effect.forkScoped(",
			"  Queue.takeBetween(queue, 1, $1).pipe(",
			"    Effect.flatMap((batch) => {",
			"      $0",
			"    }),",
			"    Effect.forever",
			"  )",
			")",
		],
	},

	"Scoped resource": {
		"prefix": "scoped",
		"body": ["Effect.acquireRelease(", "  $1,", "  ($2) => $0", ")"],
	},

	"Effect forever daemon": {
		"prefix": "daemon",
		"body": [
			"yield* Effect.forkScoped(",
			"  Effect.gen(function* () {",
			"    $0",
			"  }).pipe(",
			"    Effect.forever",
			"  )",
			")",
		],
	},

	"Queue service call": {
		"prefix": "queuecall",
		"body": [
			"Effect.gen(function* () {",
			"  const reply = yield* Deferred.make<$1>()",
			"",
			"  yield* Queue.offer(queue, {",
			"    _tag: \"$2\",",
			"    reply,",
			"    $3",
